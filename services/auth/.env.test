NODE_ENV=test
PORT=4004
HASURA_GRAPHQL_ENDPOINT=http://localhost:8080/v1/graphql
HASURA_GRAPHQL_ADMIN_SECRET=masterkey
HASURA_GRAPHQL_CLAIMS_KEY=https://hasura.io/jwt/claims
HASURA_GRAPHQL_HEADER_PREFIX=x-hasura-
USER_REGISTRATION_AUTO_ACTIVE=true
REFRESH_TOKEN_EXPIRES_IN=432000
REFRESH_TOKEN_EXPIRES_IN_MIN=10080
BASE_URL=http://localhost:4004

JWT_ALGORITHM=HS256
JWT_PRIVATE_KEY=access_tester
JWT_PRIVATE_REFRESH_KEY=refresh_tester
JWT_TOKEN_EXPIRES_MIN=15

MAIL_DRIVER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=Authorization
MAIL_SECURE=false

SMS_UZ_APP_URL=
SMS_USERNAME=
SMS_PASSWORD=
SMS_SMSC=
SMS_FROM=
SMS_CHARSET=utf-8
SMS_CODING=2